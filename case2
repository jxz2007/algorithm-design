#include<stdio.h>
#define N 5 //宏定义
int Max(int a[],int n)
{
    int Max = a[0]; //假设第一个数字最大
    for(int i = 1; i<n; i++) {
        if(a[i] > Max) {
            Max = a[i];
        }
    }
    return Max;
}

int main()
{
    //int a[]={1,2,3,4,5};//数组初始化
    //int length = sizeof(a)/sizeof(a[0]);
    int a[N],i;
    for(int i = 0; i < N; i++);
    scanf("%d",&a[i]);
    printf("最大整数是：%d",Max(a,N));
    return 0 ;
}
